From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: PixelOS Crosshatch Porter <porter@pixelos.net>
Date: Mon, 18 May 2026 00:00:04 +0000
Subject: [PATCH 0005] crosshatch: Fix audio HAL paths and mixer config

Poco F1 uses Qualcomm WCD9341 codec.
Pixel 3 XL uses Qualcomm WCD9340 codec with different mixer paths.
Also, crosshatch lacks 3.5mm jack, using USB-C audio adapter.

---
 audio_policy_configuration.xml | 28 +++++++++++++++++++++
 mixer_paths_crosshatch.xml      | 40 ++++++++++++++++++++++++++++++

diff --git a/audio_policy_configuration.xml b/audio_policy_configuration.xml
index 1111111..2222222 100644
--- a/audio_policy_configuration.xml
+++ b/audio_policy_configuration.xml
@@ -10,6 +10,34 @@
 <audioPolicyConfiguration version="7.0" xmlns:xi="http://www.w3.org/2001/XInclude">
     <globalConfiguration speaker_drc_enabled="true"/>
 
+    <!-- Pixel 3 XL (crosshatch): no 3.5mm jack, USB-C audio only -->
+    <modules>
+        <module name="primary" halVersion="3.0">
+            <attachedDevices>
+                <item>Speaker</item>
+                <item>Built-In Mic</item>
+                <item>Built-In Back Mic</item>
+            </attachedDevices>
+            <defaultOutputDevice>Speaker</defaultOutputDevice>
+            <mixPorts>
+                <mixPort name="primary output" role="source" flags="AUDIO_OUTPUT_FLAG_PRIMARY">
+                    <profile name="" format="AUDIO_FORMAT_PCM_16_BIT"
+                             samplingRates="48000"
+                             channelMasks="AUDIO_CHANNEL_OUT_STEREO"/>
+                </mixPort>
+            </mixPorts>
+            <devicePorts>
+                <devicePort tagName="Speaker" type="AUDIO_DEVICE_OUT_SPEAKER" role="sink">
+                    <gains>
+                        <gain name="" mode="AUDIO_GAIN_MODE_JOINT"
+                              minValueMB="-8400" maxValueMB="0" defaultValueMB="-3000" stepValueMB="100"/>
+                    </gains>
+                </devicePort>
+            </devicePorts>
+        </module>
+
+        <!-- USB-C audio (replaces 3.5mm on crosshatch) -->
+        <module name="usb" halVersion="2.0">
+            <attachedDevices/>
+            <mixPorts/>
+        </module>
+    </modules>
