From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: PixelOS Crosshatch Porter <porter@pixelos.net>
Date: Mon, 18 May 2026 00:00:00 +0000
Subject: [PATCH 0001] crosshatch: Enable display cutout for Pixel 3 XL notch

Pixel 3 XL has a top notch cutout (393dp wide, 93dp tall) and a bottom
chin. This patch enables the notch configuration in DisplayCutout.

---
 core/res/res/values/config.xml | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/core/res/res/values/config.xml b/core/res/res/values/config.xml
index 1234567..abcdefg 100644
--- a/core/res/res/values/config.xml
+++ b/core/res/res/values/config.xml
@@ -100,6 +100,18 @@
     <!-- Whether device has a notch -->
+    <bool name="config_fillMainBuiltInDisplayCutout">true</bool>
+
+    <!-- Pixel 3 XL notch shape: top notch + bottom chin -->
+    <string name="config_mainBuiltInDisplayCutout">
+        M 0,0
+        L -45, 0
+        L -42.6, 12.1
+        C -42.1, 13.0, -41.3, 13.7, -40.3, 14.1
+        C -39.2, 14.5, -37.6, 14.9, -35.4, 15.3
+        C -31.0, 16.1, -24.9, 16.7, -17.6, 17.0
+        L 0, 17.2
+        Z
+        @bottom
+        M 0,0 L 0,30 L 45,30 L 45,0 Z
+    </string>
+
+    <dimen name="config_displayCutoutDepth">93dp</dimen>
 </resources>
